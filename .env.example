# Supabase — create a project at https://supabase.com then copy values from
# Project Settings → API. The anon key is safe to expose in the browser.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# NOTE: the OpenRouter API key is NO LONGER stored in the browser.
# It lives only in the Supabase Edge Function secret (set via the Supabase CLI):
#   supabase secrets set OPENROUTER_API_KEY=sk-or-v1-...
# See supabase/functions/analyze-emotion (added in Phase 4).
